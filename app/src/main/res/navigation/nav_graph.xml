<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/mainFragment2">

    <activity
        android:id="@+id/mainActivity"
        android:name="com.example.colorapp.MainActivity"
        android:label="activity_main"
        tools:layout="@layout/activity_main" />
    <fragment
        android:id="@+id/addColorFragment"
        android:name="com.example.colorapp.AddColorFragment"
        android:label="AddColorFragment" />
    <fragment
        android:id="@+id/mainFragment2"
        android:name="com.example.colorapp.MainFragment"
        android:label="MainFragment" >
        <action
            android:id="@+id/action_mainFragment_to_addColorFragment"
            app:destination="@id/addColorFragment" />
        <action
            android:id="@+id/action_mainFragment_to_detailsFragment"
            app:destination="@id/detailsFragment" />
    </fragment>
    <fragment
        android:id="@+id/detailsFragment"
        android:name="com.example.colorapp.DetailsFragment"
        android:label="DetailsFragment" />
</navigation>